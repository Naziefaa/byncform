{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "byncform",
	"compatibility_date": "2025-04-04",
	"compatibility_flags": [
        "nodejs_compat"
    ],
	"main": "./workers/app.ts",
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "I4nform",
			"database_id": "1ab585a5-5d3e-4465-880b-dd65fa39eafc",
		}
	]
}